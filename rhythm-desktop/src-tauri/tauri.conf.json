{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "节奏 Rhythm",
  "version": "0.1.0",
  "identifier": "com.rhythm.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "节奏 Rhythm",
        "width": 980,
        "height": 660,
        "minWidth": 760,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:rhythm.db"]
    },
    "globalShortcut": {}
  }
}
